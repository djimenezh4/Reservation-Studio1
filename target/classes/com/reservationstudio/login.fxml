<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.reservationstudio.controller.LoginController"
           prefWidth="480" prefHeight="600">

    <!-- Red background with logo -->
    <StackPane style="-fx-background-color: #b01020;">
        <ImageView fitWidth="420" fitHeight="420"
                   opacity="0.5"
                   preserveRatio="true">
            <image>
                <Image url="@PS-Logo.png"/>
            </image>
        </ImageView>
    </StackPane>

    <!-- Login card on top -->
    <VBox alignment="CENTER" spacing="16"
          maxWidth="340" maxHeight="360"
          style="-fx-background-color: rgba(20,20,20,0.82);
                 -fx-background-radius: 12;
                 -fx-padding: 40 40 40 40;">

        <!-- App name -->
        <Label text="Reservation Studio"
               style="-fx-font-family: 'Georgia'; -fx-font-size: 22px;
                      -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>

        <Label text="Login"
               style="-fx-font-family: 'Georgia'; -fx-font-size: 12px;
                      -fx-text-fill: #aaaaaa; -fx-font-style: italic;"/>

        <Separator/>

        <!-- Username -->
        <VBox spacing="5">
            <Label text="Username"
                   style="-fx-text-fill: #cccccc; -fx-font-family: 'Georgia';
                          -fx-font-size: 11px;"/>
            <TextField fx:id="usernameField"
                       promptText="Enter username"
                       style="-fx-background-color: #2a2a2a; -fx-text-fill: white;
                              -fx-border-color: #555555; -fx-border-radius: 4;
                              -fx-background-radius: 4; -fx-font-size: 13px;
                              -fx-padding: 8 12 8 12;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="5">
            <Label text="Password"
                   style="-fx-text-fill: #cccccc; -fx-font-family: 'Georgia';
                          -fx-font-size: 11px;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter password"
                           style="-fx-background-color: #2a2a2a; -fx-text-fill: white;
                                  -fx-border-color: #555555; -fx-border-radius: 4;
                                  -fx-background-radius: 4; -fx-font-size: 13px;
                                  -fx-padding: 8 12 8 12;"/>
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: #ff6b6b; -fx-font-family: 'Georgia';
                      -fx-font-size: 11px;"/>

        <!-- Login button -->
        <Button text="Login"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;
                       -fx-font-family: 'Georgia'; -fx-font-weight: bold;
                       -fx-font-size: 13px; -fx-background-radius: 6;
                       -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
    </VBox>

</StackPane>